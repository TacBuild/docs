      "destination": "/quickstart/overview"
    },
    {
      "source": "/home/get-started/introduction",
      "destination": "/quickstart/overview"
    },
    {
      "source": "/build/quickstart",
      "destination": "/quickstart/overview"
    },
    {
      "source": "/core-concepts/overview/architecture",
      "destination": "/why-tac/overview/what-is-tac"
    },
    {
